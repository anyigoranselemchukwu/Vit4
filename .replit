modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "postgresql", "rustc", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start_fullstack.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
ADMIN_EMAIL = "admin@vit.network"
ADMIN_USERNAME = "vit_admin"
ENVIRONMENT = "development"
BACKEND_PORT = "8000"
FRONTEND_PORT = "5000"
CORS_ALLOWED_ORIGINS = "*"
AUTH_ENABLED = "false"
USE_REAL_ML_MODELS = "false"
ML_MODEL_CACHE_ENABLED = "true"
BLOCKCHAIN_ENABLED = "false"
BACKGROUND_TASK_CHECK_INTERVAL_SECONDS = "30"
BACKGROUND_TASK_MAX_RESTARTS = "5"
