# ============================================================
# VIT Sports Intelligence Network — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Database ────────────────────────────────────────────────
# SQLite (local dev)
VIT_DATABASE_URL=sqlite+aiosqlite:///./vit.db
# PostgreSQL (production) — uncomment and set when deploying
# VIT_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vit_db

# ── Auth / Security ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440         # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Application ─────────────────────────────────────────────
APP_VERSION=4.0.0
APP_ENV=development             # development | production
CORS_ALLOWED_ORIGINS=*          # production: set exact domain, e.g. https://myapp.replit.app
BACKEND_PORT=8000
FRONTEND_PORT=5000

# ── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@vit.network
ADMIN_PASSWORD=VitAdmin2025!    # Change immediately in production

# ── Football Data APIs ──────────────────────────────────────
# football-data.org (free tier: 10 req/min)
# FOOTBALL_DATA_API_KEY=your-football-data-api-key

# API-Sports / RapidAPI (alternative provider)
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# ── Telegram Alerts ─────────────────────────────────────────
# Create bot at https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# ── Paystack (NGN payments) ──────────────────────────────────
# https://dashboard.paystack.com/#/settings/developer
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_PUBLIC_KEY=pk_live_...
# PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ── Stripe (USD / card payments) ────────────────────────────
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Crypto / USDT ───────────────────────────────────────────
# USDT_MIN_CONFIRMATIONS=3
# USDT_WALLET_ADDRESS=your-usdt-wallet-address

# ── Pi Network ──────────────────────────────────────────────
# PI_API_KEY=your-pi-api-key

# ── Redis (optional — for Celery / distributed cache) ───────
# REDIS_URL=redis://localhost:6379/0

# ── Performance & Scaling ───────────────────────────────────
LSTM_MAX_TRAINING_SEQS=2000
MAX_STAKE=0.05
MIN_EDGE_THRESHOLD=0.02
